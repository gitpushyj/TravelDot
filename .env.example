# Supabase 프로젝트 설정 (Settings > API에서 복사)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Google OAuth 클라이언트 (Google Cloud Console > APIs & Services > Credentials)
# Web Client ID는 Supabase의 ID 토큰 검증에 필요하므로 iOS/Android 모두에서 동일하게 사용
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=YOUR_WEB_CLIENT_ID.apps.googleusercontent.com
# iOS Client ID는 iOS 앱용 OAuth 클라이언트
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=YOUR_IOS_CLIENT_ID.apps.googleusercontent.com

# RevenueCat 공개 API Key (RevenueCat 대시보드 > Project settings > API keys)
# 클라이언트 노출 가능한 publishable key. webhook secret은 서버(Edge Function)에만 둔다.
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_YOUR_IOS_PUBLIC_KEY
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_YOUR_ANDROID_PUBLIC_KEY
